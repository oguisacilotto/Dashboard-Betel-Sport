# Supabase
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Anthropic (Claude API) — backend only, never expose no frontend
ANTHROPIC_API_KEY=your_claude_api_key_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Nextcloud (file storage)
NEXTCLOUD_URL=https://drive.betelsport.com.br
NEXTCLOUD_USER=your_nextcloud_user
NEXTCLOUD_PASS=your_nextcloud_password

# App
VITE_APP_URL=https://dashboard-betel-sport.vercel.app
